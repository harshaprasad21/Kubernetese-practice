apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-production
spec:
  acme:
    # The Let's Encrypt API URL
    server: https://acme-v02.api.letsencrypt.org/directory
    # Let's Encrypt will email you if a certificate is about to expire
    email: harshaprasad20.hp@gmail.com
    privateKeySecretRef:
      name: letsencrypt-production-account-key
    solvers:
    - http01:
        ingress:
          class: nginx
